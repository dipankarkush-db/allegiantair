    "import os\n",
    "\n",
    "# --- Load the policy config from the shared config file (the source of truth), the SAME helper used by\n",
    "#     pii_masking_json_demo. Strategy + url_params + regex come from the file, not hardcoded here. ---\n",
    "_INLINE_POLICIES = {\n",
    "    \"name\":  {\"strategy\": \"REDACT\", \"keys\": [\"name\"], \"paths\": [],\n",
    "              \"url_params\": [\"firstName\", \"lastName\", \"fname\", \"lname\", \"first_name\", \"last_name\", \"email\"], \"regex\": []},\n",
    "    \"email\": {\"strategy\": \"REDACT\", \"keys\": [\"email\"], \"paths\": [], \"url_params\": [], \"regex\": []},\n",
    "}\n",
    "def _load_pii_policies():\n",
    "    try:\n",
    "        nb = dbutils.notebook.entry_point.getDbutils().notebook().getContext().notebookPath().get()\n",
    "        path = \"/Workspace\" + os.path.dirname(os.path.dirname(nb)) + \"/config/pii_policies.json\"  # ../config/\n",
    "        with open(path) as f:\n",
    "            print(f\"pii_policies loaded from {path}\")\n",
    "            return json.load(f)\n",
    "    except Exception as e:\n",
    "        print(f\"pii_policies: using inline default (config/pii_policies.json not read: {str(e)[:80]})\")\n",
    "        return _INLINE_POLICIES\n",
    "\n",
    "pii_policies = _load_pii_policies()\n",
    "\n",
    "approved = spark.sql(f\"SELECT * FROM {catalog}.{schema}.pii_path_proposals WHERE human_approved = true\").collect()\n",
    "if not approved:\n",
    "    print(\"No human-approved proposals — nothing to enforce. Set human_approved = true on rows in §3 first.\")\n",
    "else:\n",
    "    leaf_keys = sorted({r[\"leaf_key\"] for r in approved if r[\"leaf_key\"]})\n",
    "    # Governed-tag value = the highest-confidence approved classification that is an allowed policy in\n",
    "    # pii_policies (name/email/...). Labels like 'other' (and anything not in the config) fall back to the\n",
    "    # first policy key, since the `pii` governed tag only accepts allowed values and the ABAC policy is\n",
    "    # keyed by tag value.\n",
    "    ranked = sorted(approved, key=lambda r: -float(r[\"max_confidence\"]))\n",
    "    tag_value = next((r[\"classification\"] for r in ranked if r[\"classification\"] in pii_policies),\n",
    "                     next(iter(pii_policies)))\n",
    "\n",
    "    # Start from the file's policy for this tag_value (source of truth), then MERGE in the discovered\n",
    "    # leaf keys so the config stays in parity with what the reviewer approved.\n",
    "    pii_config = dict(pii_policies[tag_value])\n",
    "    pii_config[\"keys\"] = sorted(set(pii_config.get(\"keys\", [])) | set(leaf_keys))\n",
    "\n",
    "    print(f\"Governed tag value: {tag_value}\")\n",
    "    print(\"pii_config for the ABAC policy (base from config/pii_policies.json + discovered keys):\\n\",\n",
    "          json.dumps(pii_config, indent=2))\n",
    "    print(f\"\\nApplying governed tag {tag_key}={tag_value} to {fqtn}.{col} ...\")\n",
    "\n",
    "    spark.sql(f\"ALTER TABLE {fqtn} ALTER COLUMN {col} SET TAGS ('{tag_key}' = '{tag_value}')\")\n",
    "    print(\"Tag applied. The schema-level ABAC policy 'pii_json_mask_policy' now masks this column \"\n",
    "          \"automatically. If the discovered keys above extend config/pii_policies.json, update that file \"\n",
    "          \"and re-run §5 of pii_masking_json_demo so the policy uses the updated config.\")\n",
    "    display(spark.sql(f\"\"\"\n",
    "      SELECT column_name, tag_name, tag_value FROM {catalog}.information_schema.column_tags\n",
    "      WHERE schema_name='{schema}' AND table_name='{table}'\n",
    "    \"\"\"))"
   ]
  }
