{
  "datasets": [
    {
      "name": "ds_all",
      "displayName": "ds_all",
      "queryLines": [
        "WITH med AS (\n  SELECT scale, variant, pattern,\n         min(execution_ms) AS exec_ms,\n         min(total_ms)     AS total_ms,\n         max(read_rows)    AS read_rows\n  FROM dkushari_uc.allegiant_air_perf.perf_results GROUP BY scale, variant, pattern\n),\nsumm AS (\n  SELECT m.scale, m.pattern, m.variant,\n         round(m.exec_ms,0) AS exec_ms, round(m.total_ms,0) AS total_ms, m.read_rows,\n         round(m.exec_ms - b.exec_ms, 0) AS overhead_ms,\n         round(100.0*(m.exec_ms - b.exec_ms)/nullif(b.exec_ms,0), 1) AS overhead_pct,\n         CASE m.scale WHEN '1m' THEN 1 WHEN '10m' THEN 2 WHEN '100m' THEN 3 END AS scale_ord\n  FROM med m JOIN med b ON m.scale=b.scale AND m.pattern=b.pattern AND b.variant='baseline'\n)\nSELECT scale, pattern, variant, exec_ms, total_ms, read_rows, overhead_ms, overhead_pct,\n       scale_ord, concat(cast(scale_ord AS STRING),'_',scale) AS scale_sortable\nFROM summ"
      ]
    },
    {
      "name": "ds_s1m",
      "displayName": "ds_s1m",
      "queryLines": [
        "SELECT * FROM (\nWITH med AS (\n  SELECT scale, variant, pattern,\n         min(execution_ms) AS exec_ms,\n         min(total_ms)     AS total_ms,\n         max(read_rows)    AS read_rows\n  FROM dkushari_uc.allegiant_air_perf.perf_results GROUP BY scale, variant, pattern\n),\nsumm AS (\n  SELECT m.scale, m.pattern, m.variant,\n         round(m.exec_ms,0) AS exec_ms, round(m.total_ms,0) AS total_ms, m.read_rows,\n         round(m.exec_ms - b.exec_ms, 0) AS overhead_ms,\n         round(100.0*(m.exec_ms - b.exec_ms)/nullif(b.exec_ms,0), 1) AS overhead_pct,\n         CASE m.scale WHEN '1m' THEN 1 WHEN '10m' THEN 2 WHEN '100m' THEN 3 END AS scale_ord\n  FROM med m JOIN med b ON m.scale=b.scale AND m.pattern=b.pattern AND b.variant='baseline'\n)\nSELECT scale, pattern, variant, exec_ms, total_ms, read_rows, overhead_ms, overhead_pct,\n       scale_ord, concat(cast(scale_ord AS STRING),'_',scale) AS scale_sortable\nFROM summ\n) WHERE scale='1m'"
      ]
    },
